# Copy this file to .streamlit/secrets.toml for LOCAL dev (it is gitignored),
# OR paste these into Streamlit Community Cloud -> your app -> Settings -> Secrets.

# Required for the Safety Agent page (runs the agent in-process):
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional overrides — defaults point at the live Railway backends:
# TRIAGE_API = "https://fde-sprint-production.up.railway.app"
# RAG_API    = "https://reg-rag-production.up.railway.app"
